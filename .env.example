# =============================================
# ECOVIBE CONCIERGE - MULTI-AGENT SUSTAINABILITY SUITE
# .env.example - Template Configuration File
# Copy this file to '.env' and populate with your secure credential strings
# =============================================

# ================== SYSTEM & RUNTIME CONFIG ==================
PROJECT_NAME={Enter your project name}
ENVIRONMENT=development
PORT=8080
IP_ADDRESS=0.0.0.0
DEBUG=true
LOG_LEVEL=INFO

# Antigravity / Terminal Settings
PREFERRED_TERMINAL=git-bash

# ================== Shared UV Cache Directory ================
# (Optimizes Windows build times)
# Update this path to match your local workstation configuration
UV_CACHE_DIR={Enter file path here}\uv-cache

# ================== GOOGLE CREDENTIALS & INTEGRATIONS =========
# Target Google Cloud Project ID hosting your active Firestore Database
GOOGLE_CLOUD_PROJECT={Enter your google cloud project id}
GOOGLE_CLOUD_REGION={Enter your google cloud region}

# Standard API Key expected natively by the google-genai SDK.
# [Enterprise Guide]: Maintain two distinct environment files to protect budgets:
# Use a Free Tier AI Studio key in your '.env.local' development sandbox.
# Use your Paid Tier AI Studio key (linked to a billed GCP project) in production.
GEMINI_API_KEY="{Enter Google AI Studio Key}"

# Developer Knowledge SSE-based MCP Client Credentials
# Prevents spawning local Windows Node.js popups by using the cloud server
GOOGLE_DEV_KNOWLEDGE_API_KEY="{Enter Google Developer Knowledge Key}"

# ================== REASONING CORE SETTINGS ==================
# Model configurations mapped to EcoVibe Swarm channels
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Generation thresholds
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=8192

# ================== SECURITY & GUARDRAILS ==================
# Enforces manual confirmation cards before committing state actions (e.g. Calendar writes)
ENABLE_HUMAN_IN_THE_LOOP=true
LOG_SENSITIVE_DATA=false

# ================== OPTIONAL SERVICES ==================
# Google Maps API Key - Required only for real-world transit optimization routing
GOOGLE_MAPS_API_KEY="{Enter your Google Maps API Key}"

# ================== DEPLOYMENTS ====================
TARGET_URL="{Enter your green Cloud Run Deployment URL}"



