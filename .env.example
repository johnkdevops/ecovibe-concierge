# =============================================
# EcoVibe Concierge - Multi-Agent System
# .env.example - Copy to .env and customize
# =============================================

# ================== UV CACHE (Shared) ==================
# Use your shared cache across all Antigravity projects
UV_CACHE_DIR={Enter file path here}\uv-cache

# ================== PROJECT CONFIG ==================
PROJECT_NAME=ecovibe-concierge
ENVIRONMENT=development

# ================== GOOGLE CLOUD CONFIG ==================
GOOGLE_CLOUD_PROJECT={Enter google cloud project id}
GOOGLE_CLOUD_REGION={Enter google cloud region}

# Vertex AI / Gemini Settings
GEMINI_MODEL=gemini-3.5 flash (medium)  
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192

# Vertex AI Agent Engine
AGENT_ENGINE_LOCATION={Enter Vertex AI Engine Location}

# ================== AGENT CONFIG ==================
ORCHESTRATOR_MODEL=gemini-3.5 Flash (medium)
TRACKER_MODEL=gemini-3.5 Flash (medium)
RESEARCHER_MODEL=gemini-3.5 Flash (medium)
PLANNER_MODEL=gemini-3.5 Flash (medium)

# Memory & Session Settings
MEMORY_TTL_DAYS=30
MAX_SESSION_TURNS=50

# ================== EXTERNAL SERVICES ==================
# Google Maps API Key (optional - for greener routing)
GOOGLE_MAPS_API_KEY={Enter your Google Maps API Key}

# Optional: Weather API or other services
# OPENWEATHER_API_KEY=your-key-here

# ================== SECURITY & PRIVACY ==================
# Set to true in production
ENABLE_HUMAN_IN_THE_LOOP=true
LOG_SENSITIVE_DATA=false

# ================== DEVELOPMENT ==================
DEBUG=true
LOG_LEVEL=INFO

# Antigravity / Terminal Settings
PREFERRED_TERMINAL=git-bash